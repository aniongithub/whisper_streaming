    "version": "0.2.0",
    "configurations": [

        {
            "name": "Whisper online server",
            "type": "debugpy",
            "request": "launch",
            "program": "whisper_online_server.py",
            "args": [
                "--warmup-file", "assets/jfk.flac",
                "--model", "large-v2",
                "--language", "en",
                "--vad", "--vac",
                "--buffer_trimming", "sentence" 
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}